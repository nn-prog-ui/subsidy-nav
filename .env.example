DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subsidy_navigator
PORT=4000
JWT_SECRET=supersecretkey
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234
NODE_ENV=development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=yourapppassword
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://subsidy-nav.jp

# LINE Notify (optional)
LINE_NOTIFY_TOKEN=your_line_notify_token

# Redis (optional) - 設定すると分散キャッシュとして利用。未設定ならインメモリ
REDIS_URL=redis://localhost:6379

# Jグランツ公式API（補助金の一次情報取り込み元）。既定値で動作
JGRANTS_API_BASE=https://api.jgrants-portal.go.jp/exp/v1/public

# Claude API（AI申請ガイド生成）。未設定なら機能は無効（既存機能には影響なし）
ANTHROPIC_API_KEY=

# J-Net21 支援情報フィード（補助金系の項目をレビューキューへ取り込む）。実フィードURLは要確認
JNET21_FEED_URL=https://j-net21.smrj.go.jp/rss/snavi.rdf
