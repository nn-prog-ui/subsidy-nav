generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subsidy {
  id               String    @id @default(cuid())
  title            String
  description      String
  category         String
  targetType       String
  prefecture       String
  municipalityCode String?
  municipalityName String?
  level            String
  maxAmount        BigInt?
  subsidyRate      String?
  applicationStart DateTime?
  applicationEnd   DateTime?
  status           String    @default("active")
  applicationUrl   String?
  scrapeUrl        String?
  scrapedAt        DateTime?
  contactPhone     String?
  contactEmail     String?
  requirements      String?
  notes             String?
  difficulty        String?   // 申請難易度: easy | medium | hard
  estimatedDays     Int?      // 申請にかかる目安日数
  applicationSteps  String[]  // 申請ステップ（順序付き）
  requiredDocuments String[]  // 必要書類
  viewCount         Int       @default(0) // 累計閲覧数
  source            String?   // 取り込み元（例: jgrants / manual / scrape）
  sourceId          String?   @unique // 取り込み元での一意ID（再取り込み時のupsertキー）
  applicationGuide  ApplicationGuide? // AIが生成した申請ガイド（コンサル納品物）
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([prefecture])
  @@index([category])
  @@index([status])
  @@index([viewCount])
  @@index([level])
}

// Phase 31: AIが生成する申請ガイド（コンサル納品物）。補助金1件につき最新版を1件保持。
model ApplicationGuide {
  id               String   @id @default(cuid())
  subsidyId        String   @unique
  subsidy          Subsidy  @relation(fields: [subsidyId], references: [id], onDelete: Cascade)
  overview         String                // 総評・採択のポイント
  writingTips      String[]              // 申請書の書き方のコツ
  preparation      String[]              // 事前に準備すべき書類・体制
  schedule         String[]              // 申請〜入金の想定スケジュール
  disbursementDays Int?                  // 申請から入金までの想定日数
  pitfalls         String[]              // よくある不採択理由・注意点
  model            String                // 生成に使用したモデル
  generatedAt      DateTime @default(now())
}

// Phase 32: AIが公式サイト/告示から抽出した補助金候補。管理者レビュー後に Subsidy へ公開。
model ExtractedSubsidy {
  id               String    @id @default(cuid())
  sourceUrl        String
  title            String
  description      String
  category         String
  targetType       String
  prefecture       String
  municipalityName String?
  level            String    @default("市区町村")
  maxAmount        BigInt?
  subsidyRate      String?
  applicationStart DateTime?
  applicationEnd   DateTime?
  applicationUrl   String?
  confidence       String    @default("medium") // high|medium|low（抽出確度）
  status           String    @default("pending") // pending|approved|rejected
  publishedId      String?   // 承認時に作成した Subsidy.id
  model            String
  createdAt        DateTime  @default(now())

  @@index([status, createdAt])
}

model Alert {
  id                String   @id @default(cuid())
  email             String
  token             String   @unique @default(cuid())
  verified          Boolean  @default(false)
  prefectures       String[]
  municipalityCodes String[]
  categories        String[]
  keywords          String[]
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
}

model ConsultingRequest {
  id         String   @id @default(cuid())
  name       String
  email      String
  company    String?
  phone      String?
  prefecture String?
  industry   String?
  employees  String?
  budget     String?
  message    String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MatchingResult {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  prefecture String
  industry   String
  employees  String
  subsidyIds String[]
  createdAt  DateTime @default(now())
}

model Template {
  id            String   @id @default(cuid())
  title         String
  category      String
  description   String
  fileName      String
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model ScrapeLog {
  id             String   @id @default(cuid())
  targetCode     String
  targetName     String
  status         String
  subsidiesFound Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
}

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  passwordHash     String?
  name             String?
  emailVerified    Boolean               @default(false)
  verifyToken      String?               @unique
  resetToken       String?               @unique
  resetTokenExpiry DateTime?
  provider         String                @default("email")
  shareToken       String?               @unique
  notifyProgress   Boolean               @default(true)
  favorites        Favorite[]
  progress         ApplicationProgress[]
  savedSearches    SavedSearch[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String // 例: "category=IT・デジタル&prefecture=東京都"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ApplicationProgress {
  id        String   @id @default(cuid())
  userId    String
  subsidyId String
  status    String   @default("considering") // considering|preparing|applied|approved|rejected
  memo      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, subsidyId])
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String // create|update|delete
  target     String // subsidy|user|...
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String // view|search|match
  subsidyId String?
  keyword   String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([subsidyId])
}

model SubsidyRevision {
  id         String   @id @default(cuid())
  subsidyId  String
  adminEmail String?
  changes    String // JSON: { field: { from, to } }
  createdAt  DateTime @default(now())

  @@index([subsidyId])
  @@index([createdAt])
}

model SubsidyReport {
  id        String   @id @default(cuid())
  subsidyId String
  reason    String // outdated | wrong_info | broken_link | other
  detail    String?
  email     String?
  status    String   @default("open") // open | resolved | dismissed
  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([subsidyId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  subsidyId String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subsidyId])
  @@index([userId])
}
