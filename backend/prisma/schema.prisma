generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subsidy {
  id               String    @id @default(cuid())
  title            String
  description      String
  category         String
  targetType       String
  prefecture       String
  municipalityCode String?
  municipalityName String?
  level            String
  maxAmount        BigInt?
  subsidyRate      String?
  applicationStart DateTime?
  applicationEnd   DateTime?
  status           String    @default("active")
  applicationUrl   String?
  scrapeUrl        String?
  scrapedAt        DateTime?
  contactPhone     String?
  contactEmail     String?
  requirements      String?
  notes             String?
  difficulty        String?   // 申請難易度: easy | medium | hard
  estimatedDays     Int?      // 申請にかかる目安日数
  applicationSteps  String[]  // 申請ステップ（順序付き）
  requiredDocuments String[]  // 必要書類
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([prefecture])
  @@index([category])
  @@index([status])
  @@index([level])
}

model Alert {
  id                String   @id @default(cuid())
  email             String
  token             String   @unique @default(cuid())
  verified          Boolean  @default(false)
  prefectures       String[]
  municipalityCodes String[]
  categories        String[]
  keywords          String[]
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
}

model ConsultingRequest {
  id         String   @id @default(cuid())
  name       String
  email      String
  company    String?
  phone      String?
  prefecture String?
  industry   String?
  employees  String?
  budget     String?
  message    String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MatchingResult {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  prefecture String
  industry   String
  employees  String
  subsidyIds String[]
  createdAt  DateTime @default(now())
}

model Template {
  id            String   @id @default(cuid())
  title         String
  category      String
  description   String
  fileName      String
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model ScrapeLog {
  id             String   @id @default(cuid())
  targetCode     String
  targetName     String
  status         String
  subsidiesFound Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
}

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  passwordHash     String?
  name             String?
  emailVerified    Boolean               @default(false)
  verifyToken      String?               @unique
  resetToken       String?               @unique
  resetTokenExpiry DateTime?
  provider         String                @default("email")
  shareToken       String?               @unique
  favorites        Favorite[]
  progress         ApplicationProgress[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model ApplicationProgress {
  id        String   @id @default(cuid())
  userId    String
  subsidyId String
  status    String   @default("considering") // considering|preparing|applied|approved|rejected
  memo      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, subsidyId])
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String // create|update|delete
  target     String // subsidy|user|...
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String // view|search|match
  subsidyId String?
  keyword   String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([subsidyId])
}

model SubsidyRevision {
  id         String   @id @default(cuid())
  subsidyId  String
  adminEmail String?
  changes    String // JSON: { field: { from, to } }
  createdAt  DateTime @default(now())

  @@index([subsidyId])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  subsidyId String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subsidyId])
  @@index([userId])
}
